.DS_Store
Thumbs.db

# Build artifacts
build/
dist/

# Coverage
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Wandb
wandb/

# Large model files (we'll mount these as volumes)
!models.tar.xz
