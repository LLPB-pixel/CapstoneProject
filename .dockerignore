# Docker ignore file

# Git
.git
.gitignore

# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
.env

# IDE
.vscode/
.idea/

# Large files
*.tar.gz
*.zip
*.rar

# Logs and temporary files
*.log
tmp/
temp/

